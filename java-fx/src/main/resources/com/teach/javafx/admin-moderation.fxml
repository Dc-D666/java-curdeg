<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.AdminModerationController" stylesheets="@css/bbs-comments.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <children>
                <Label text="内容审核管理" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                <Button fx:id="pendingOnlyButton" text="待审核" style="-fx-background-color: #2196F3; -fx-text-fill: white;" onAction="#togglePendingOnly" />
                <Button fx:id="allPostsButton" text="全部帖子" style="-fx-background-color: #f0f0f0;" onAction="#toggleAllPosts" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <TableView fx:id="postTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="80" text="ID" />
                    <TableColumn fx:id="titleColumn" prefWidth="300" text="标题" />
                    <TableColumn fx:id="authorColumn" prefWidth="120" text="作者" />
                    <TableColumn fx:id="createTimeColumn" prefWidth="180" text="发布时间" />
                    <TableColumn fx:id="moderationStatusColumn" prefWidth="120" text="审核状态" />
                    <TableColumn fx:id="moderatorColumn" prefWidth="120" text="审核人员" />
                    <TableColumn fx:id="moderationTimeColumn" prefWidth="180" text="审核时间" />
                    <TableColumn fx:id="actionColumn" prefWidth="100" text="操作" />
                </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="10">
                <children>
                    <Button fx:id="prevPageButton" text="上一页" onAction="#prevPage" />
                    <Label fx:id="pageInfoLabel" text="第 1 / 1 页" />
                    <Button fx:id="nextPageButton" text="下一页" onAction="#nextPage" />
                </children>
            </HBox>

            <VBox fx:id="moderationPanel" spacing="10" style="-fx-background-color: #f9f9f9; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-border-radius: 5;">
                <children>
                    <Label text="帖子详情" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                    <Label fx:id="selectedPostTitleLabel" text="" style="-fx-font-size: 16px;" />
                    <VBox fx:id="moderationFlowCard" spacing="12.0" styleClass="moderation-flow-card moderation-flow-card-compact">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <children>
                                    <Label text="审核流转" styleClass="moderation-flow-title moderation-flow-title-compact" />
                                    <Label text="后台视角" styleClass="moderation-flow-badge" />
                                </children>
                            </HBox>
                            <HBox fx:id="moderationFlowStepsBox" alignment="CENTER_LEFT" spacing="0.0" />
                            <Label fx:id="moderationFlowSummaryLabel" styleClass="moderation-flow-summary moderation-flow-summary-compact" text="选择帖子后显示当前审核流转" wrapText="true" />
                        </children>
                    </VBox>
                    <TextArea fx:id="postContentArea" prefRowCount="8" editable="false" wrapText="true" />

                    <HBox spacing="20">
                        <children>
                            <VBox spacing="5">
                                <Label text="审核决定" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="decisionChoiceBox" prefWidth="150" />
                            </VBox>
                            <VBox spacing="5">
                                <Label text="违规等级" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="violationLevelChoiceBox" prefWidth="120" />
                            </VBox>
                            <VBox spacing="5">
                                <Label text="违规类型" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="violationTypeChoiceBox" prefWidth="150" />
                            </VBox>
                        </children>
                    </HBox>

                    <Label text="备注" style="-fx-font-weight: bold;" />
                    <TextArea fx:id="remarkArea" prefRowCount="3" wrapText="true" />

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <children>
                            <Button fx:id="cancelModerationButton" text="取消" onAction="#hideModerationPanel" style="-fx-background-color: #f0f0f0;" />
                            <Button fx:id="submitModerationButton" text="提交审核" onAction="#submitModeration" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                        </children>
                    </HBox>
                </children>
            </VBox>
        </VBox>
    </center>
</BorderPane>
