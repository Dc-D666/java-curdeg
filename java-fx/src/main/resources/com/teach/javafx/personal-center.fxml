<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.PersonalCenterController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox spacing="10.0" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 10 0;" text="个人中心" />
            <Button fx:id="profileButton" mnemonicParsing="false" onAction="#onProfile" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="个人资料" />
            <Button fx:id="myPostsButton" mnemonicParsing="false" onAction="#onMyPosts" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="我的帖子" />
            <Button fx:id="myFavoritesButton" mnemonicParsing="false" onAction="#onMyFavorites" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="我的收藏" />
            <Button fx:id="myFollowingButton" mnemonicParsing="false" onAction="#onMyFollowing" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="我的关注" />
            <Button fx:id="myFollowersButton" mnemonicParsing="false" onAction="#onMyFollowers" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="我的粉丝" />
            <Button fx:id="statisticsButton" mnemonicParsing="false" onAction="#onStatistics" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="数据统计" />
            <Button fx:id="changePasswordButton" mnemonicParsing="false" onAction="#onPasswordChange" prefWidth="180.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8;" text="修改密码" />
         </children>
      </VBox>
   </left>
   <center>
      <StackPane fx:id="contentStackPane">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </StackPane>
   </center>
</BorderPane>