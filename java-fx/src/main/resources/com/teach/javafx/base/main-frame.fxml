<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<!-- 前端应用主框架FXML配置文件 对应页面交互控制类 com.teach.javafx.controller.base.MainFrameController -->
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TreeView?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teach.javafx.controller.base.MainFrameController">
  <top>
    <MenuBar fx:id="menuBar">
      <menus>
        <Menu fx:id="menuHome" text="首页">
          <items>
            <MenuItem text="帖子广场" onAction="#onPostSquareClick" />
          </items>
        </Menu>
        <Menu fx:id="menuExportMenu" text="导出" visible="false">
          <items>
            <MenuItem text="导出帖子数据" onAction="#onExportPostsClick" />
            <MenuItem text="导出用户数据" onAction="#onExportUsersClick" />
            <MenuItem text="导出统计报表" onAction="#onExportStatsClick" />
          </items>
        </Menu>
        <Menu fx:id="menuSettings" text="设置">
          <items>
            <MenuItem text="系统设置" onAction="#onSystemSettingsClick" />
            <SeparatorMenuItem />
            <MenuItem fx:id="menuLogout" text="退出登录" onAction="#onLogoutMenuClick" />
          </items>
        </Menu>
        <Menu fx:id="menuHelp" text="帮助">
          <items>
            <MenuItem text="关于" onAction="#onAboutClick" />
            <MenuItem text="反馈与建议" onAction="#onFeedbackClick" />
          </items>
        </Menu>
        <Menu fx:id="menuSwitchAccount" text="切换账号" />
      </menus>
    </MenuBar>
  </top>
  <left>
    <TreeView fx:id="menuTree" prefWidth="200"/>
  </left>
  <center>
    <TabPane fx:id="contentTabPane"  tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
    </TabPane>
  </center>
  <bottom>
    <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0">
      <children>
        <Label maxHeight="1.7976931348623157E308" maxWidth="-1.0" text="Left status" HBox.hgrow="ALWAYS" fx:id="systemPrompt" >
          <font>
            <Font size="11.0" fx:id="x3" />
          </font>
          <textFill >
            <Color red="0.625" green="0.625" blue="0.625" fx:id="x4" />
          </textFill>
        </Label>
        <Pane prefHeight="-1.0" prefWidth="-1.0" HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_LEFT" spacing="5.0">
          <children>
            <Label fx:id="unreadNotificationLabel" font="$x3" style="-fx-text-fill: red; -fx-cursor: hand;" text="" HBox.hgrow="NEVER" />
            <Label font="$x3" maxWidth="-1.0" text="Right status" textFill="$x4" HBox.hgrow="NEVER" />
          </children>
        </HBox>
      </children>
      <padding>
        <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
      </padding>
    </HBox>
  </bottom>
</BorderPane>
