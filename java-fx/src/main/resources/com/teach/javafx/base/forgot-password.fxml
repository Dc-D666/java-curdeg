<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="vbox" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.base.ForgotPasswordController">
    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
        <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0"
              style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@../picture/logo.jpg" /></image>
            </ImageView>
            <Label text="学生交流社区 - 忘记密码" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <VBox spacing="15.0">
                <TextField fx:id="studentIdField" promptText="请输入学号"
                           style="-fx-background-radius: 4px; -fx-border-radius: 4px; -fx-border-color: #d9d9d9; -fx-border-width: 1px; -fx-padding: 10px; -fx-pref-height: 36px; -fx-focus-color: #1890ff; -fx-faint-focus-color: #1890ff22;" />
                <TextField fx:id="emailField" promptText="请输入注册邮箱"
                           style="-fx-background-radius: 4px; -fx-border-radius: 4px; -fx-border-color: #d9d9d9; -fx-border-width: 1px; -fx-padding: 10px; -fx-pref-height: 36px; -fx-focus-color: #1890ff; -fx-faint-focus-color: #1890ff22;" />
                <HBox spacing="10.0">
                    <TextField fx:id="emailCodeField" promptText="请输入验证码" HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 4px; -fx-border-radius: 4px; -fx-border-color: #d9d9d9; -fx-border-width: 1px; -fx-padding: 10px; -fx-pref-height: 36px; -fx-focus-color: #1890ff; -fx-faint-focus-color: #1890ff22;" />
                    <Button fx:id="sendCodeButton" text="发送验证码" minWidth="100.0" onAction="#onSendCodeButtonClick"
                            style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-background-radius: 4px; -fx-pref-height: 36px; -fx-cursor: hand;" />
                </HBox>
                <PasswordField fx:id="newPasswordField" promptText="请输入新密码"
                               style="-fx-background-radius: 4px; -fx-border-radius: 4px; -fx-border-color: #d9d9d9; -fx-border-width: 1px; -fx-padding: 10px; -fx-pref-height: 36px; -fx-focus-color: #1890ff; -fx-faint-focus-color: #1890ff22;" />
                <PasswordField fx:id="confirmPasswordField" promptText="请确认新密码"
                               style="-fx-background-radius: 4px; -fx-border-radius: 4px; -fx-border-color: #d9d9d9; -fx-border-width: 1px; -fx-padding: 10px; -fx-pref-height: 36px; -fx-focus-color: #1890ff; -fx-faint-focus-color: #1890ff22;" />
            </VBox>
            <Button fx:id="resetButton" text="重置密码" maxWidth="Infinity" onAction="#onResetButtonClick"
                    style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-background-radius: 4px; -fx-pref-height: 40px; -fx-cursor: hand;" />
            <HBox alignment="CENTER">
                <Hyperlink onAction="#onBackButtonClick" text="返回登录"
                           style="-fx-text-fill: #1890ff; -fx-underline: false;" />
            </HBox>
        </VBox>
    </StackPane>
</VBox>
