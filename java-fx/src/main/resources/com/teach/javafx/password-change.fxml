<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true"
            styleClass="profile-scroll-pane" stylesheets="@css/personal-center.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.PasswordChangeController">
    <content>
        <VBox spacing="18.0" styleClass="profile-page">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="24.0"/>
            </padding>
            <children>
                <VBox spacing="6.0" styleClass="profile-title-row">
                    <children>
                        <Label text="修改密码" styleClass="profile-title"/>
                        <Label text="先验证原密码，再获取绑定邮箱验证码，最后提交新密码。" styleClass="profile-subtitle"/>
                    </children>
                </VBox>

                <HBox spacing="8.0" styleClass="security-step-row">
                    <children>
                        <Label text="1" styleClass="security-step-badge"/>
                        <Label text="验证原密码" styleClass="security-step-text"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="2" styleClass="security-step-badge"/>
                        <Label text="获取邮箱验证码" styleClass="security-step-text"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="3" styleClass="security-step-badge"/>
                        <Label text="提交新密码" styleClass="security-step-text"/>
                    </children>
                </HBox>

                <VBox spacing="18.0" styleClass="profile-card password-card" maxWidth="760.0">
                    <children>
                        <HBox spacing="14.0" alignment="CENTER_LEFT">
                            <children>
                                <Region styleClass="password-card-accent"/>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="安全验证" styleClass="section-title"/>
                                        <Label fx:id="emailInfoLabel" text="验证码将发送到你的绑定邮箱。" styleClass="section-hint"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Separator opacity="0.7"/>

                        <GridPane hgap="14.0" vgap="14.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="92.0" prefWidth="108.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <children>
                                <Label text="原密码" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <PasswordField fx:id="oldPasswordField" promptText="请输入当前密码"
                                               styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="新密码" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <PasswordField fx:id="newPasswordField" promptText="8-20位，至少包含字母和数字"
                                               styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="确认密码" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <PasswordField fx:id="confirmPasswordField" promptText="请再次输入新密码"
                                               styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="邮箱验证码" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                    <children>
                                        <TextField fx:id="emailCodeField" promptText="请输入6位验证码"
                                                   styleClass="form-input" HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="sendCodeButton" mnemonicParsing="false" text="发送验证码"
                                                prefWidth="122.0" styleClass="secondary-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </GridPane>

                        <VBox spacing="8.0" styleClass="password-note-box">
                            <children>
                                <Label text="注意事项" styleClass="password-note-title"/>
                                <Label text="验证码 5 分钟内有效。修改成功后会返回登录页，请使用新密码重新登录。"
                                       styleClass="section-hint"/>
                            </children>
                        </VBox>

                        <Label fx:id="statusLabel" managed="false" visible="false" styleClass="password-status"/>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="changeButton" mnemonicParsing="false" text="确认修改"
                                        prefWidth="128.0" styleClass="primary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
