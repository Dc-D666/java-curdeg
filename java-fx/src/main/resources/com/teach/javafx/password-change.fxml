<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.PasswordChangeController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="修改密码" />
         </children>
      </VBox>
   </top>
   <center>
      <GridPane alignment="CENTER" hgap="15.0" vgap="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 14px;" text="原密码：" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <PasswordField fx:id="oldPasswordField" prefWidth="250.0" promptText="请输入原密码" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label style="-fx-font-size: 14px;" text="新密码：" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <PasswordField fx:id="newPasswordField" prefWidth="250.0" promptText="请输入新密码" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label style="-fx-font-size: 14px;" text="确认密码：" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <PasswordField fx:id="confirmPasswordField" prefWidth="250.0" promptText="请再次输入新密码" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Button fx:id="changeButton" mnemonicParsing="false" prefWidth="120.0" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-font-size: 14px;" text="修改密码" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
      </GridPane>
   </center>
</BorderPane>
