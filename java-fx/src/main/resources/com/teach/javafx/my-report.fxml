<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.MyReportController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="我的举报" />
            <Button fx:id="refreshButton" mnemonicParsing="false" text="刷新" />
         </children>
      </HBox>
   </top>
   <center>
      <TableView fx:id="reportTableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="targetTypeColumn" prefWidth="100.0" text="举报类型" />
          <TableColumn fx:id="reasonColumn" prefWidth="250.0" text="举报原因" />
          <TableColumn fx:id="statusColumn" prefWidth="100.0" text="状态" />
          <TableColumn fx:id="createTimeColumn" prefWidth="150.0" text="举报时间" />
          <TableColumn fx:id="handleTimeColumn" prefWidth="150.0" text="处理时间" />
          <TableColumn fx:id="handleRemarkColumn" prefWidth="200.0" text="处理备注" />
        </columns>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label fx:id="pageInfoLabel" text="共 0 条，第 1 页" />
            <Button fx:id="prevButton" mnemonicParsing="false" text="上一页" />
            <Button fx:id="nextButton" mnemonicParsing="false" text="下一页" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
