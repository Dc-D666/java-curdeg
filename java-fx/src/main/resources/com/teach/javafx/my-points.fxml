<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="profile-scroll-pane" stylesheets="@css/personal-center.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teach.javafx.controller.MyPointsController">
    <content>
        <VBox spacing="18.0" styleClass="profile-page">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <children>
                <!-- 当前积分信息 -->
                <VBox spacing="14.0" styleClass="profile-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="section-title" text="我的积分" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="18.0">
                            <children>
                                <ImageView fx:id="levelIcon" fitHeight="72.0" fitWidth="72.0" preserveRatio="true" />
                                <VBox alignment="CENTER_LEFT" spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="levelName" styleClass="profile-title" text="--" />
                                        <Label fx:id="pointsLabel" styleClass="profile-subtitle" text="-- 山竹瓣" />
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Region fx:id="progressBar" HBox.hgrow="ALWAYS" maxWidth="350" minHeight="10" style="-fx-background-color: #f0f0f0; -fx-background-radius: 5;" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="progressLabel" styleClass="profile-subtitle" text="--" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- 快捷操作 -->
                        <HBox spacing="12.0">
                            <children>
                                <Button fx:id="checkHistoryBtn" styleClass="btn-secondary" text="积分记录" />
                                <Button fx:id="checkRankBtn" styleClass="btn-secondary" text="积分排行" />
                                <Button fx:id="checkPrivilegesBtn" styleClass="btn-secondary" text="等级特权" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- 积分获取规则 -->
                <VBox spacing="14.0" styleClass="profile-card">
                    <children>
                        <Label styleClass="section-title" text="获取积分" />
                        <VBox fx:id="earnPointsBox" spacing="10.0">
                            <padding>
                                <Insets bottom="6.0" left="2.0" right="2.0" top="2.0" />
                            </padding>
                        </VBox>
                    </children>
                </VBox>

                <!-- 积分消耗规则 -->
                <VBox spacing="14.0" styleClass="profile-card">
                    <children>
                        <Label styleClass="section-title" text="积分消耗" />
                        <VBox fx:id="spendPointsBox" spacing="10.0">
                            <padding>
                                <Insets bottom="6.0" left="2.0" right="2.0" top="2.0" />
                            </padding>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>