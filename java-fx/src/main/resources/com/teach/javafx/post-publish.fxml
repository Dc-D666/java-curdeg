<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.PostPublishController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <center>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="标题：" />
                  <TextField fx:id="titleTextField" prefWidth="400.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="板块：" />
                  <ComboBox fx:id="boardComboBox" prefWidth="200.0" />
               </children>
            </HBox>
            <VBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label text="内容：" />
                  <TextArea fx:id="contentTextArea" prefHeight="300.0" prefWidth="600.0" wrapText="true" />
               </children>
            </VBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="图片 URL（逗号分隔）：" />
                  <TextField fx:id="imageUrlsTextField" prefWidth="400.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="publishButton" mnemonicParsing="false" prefWidth="100.0" text="发布" />
                  <Button fx:id="cancelButton" mnemonicParsing="false" prefWidth="100.0" text="取消" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
