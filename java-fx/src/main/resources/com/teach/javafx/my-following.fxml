<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.MyFollowingController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <BorderPane>
            <top>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="我的关注"/>
                        <Label fx:id="followingTotalLabel" style="-fx-text-fill: white;" text=""/>
                        <Button fx:id="followingRefreshButton" mnemonicParsing="false" text="刷新"/>
                    </children>
                </HBox>
            </top>
            <center>
                <TableView fx:id="followingTableView" prefHeight="200.0" prefWidth="200.0">
                    <columns>
                        <TableColumn fx:id="followingAvatarColumn" prefWidth="80.0" text="头像"/>
                        <TableColumn fx:id="followingNicknameColumn" prefWidth="120.0" text="昵称"/>
                        <TableColumn fx:id="followingSignatureColumn" prefWidth="200.0" text="个性签名"/>
                        <TableColumn fx:id="followingPostCountColumn" prefWidth="80.0" text="发帖数"/>
                        <TableColumn fx:id="followingFollowerCountColumn" prefWidth="80.0" text="粉丝数"/>
                        <TableColumn fx:id="followingTimeColumn" prefWidth="150.0" text="关注时间"/>
                        <TableColumn fx:id="followingActionColumn" prefWidth="120.0" text="操作"/>
                    </columns>
                </TableView>
            </center>
            <bottom>
                <HBox alignment="CENTER" spacing="20.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                    <children>
                        <Button fx:id="followingPrevButton" mnemonicParsing="false" text="上一页"/>
                        <Label fx:id="followingPageInfoLabel" text=""/>
                        <Button fx:id="followingNextButton" mnemonicParsing="false" text="下一页"/>
                    </children>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
