<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.MyFavoritesController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="我的收藏"/>
                <Label fx:id="totalLabel" text=""/>
                <Button fx:id="refreshButton" mnemonicParsing="false" text="刷新" />
            </children>
        </HBox>
    </top>
    <center>
        <TableView fx:id="postTableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="titleColumn" prefWidth="200.0" text="标题"/>
                <TableColumn fx:id="contentColumn" prefWidth="300.0" text="内容摘要"/>
                <TableColumn fx:id="authorColumn" prefWidth="100.0" text="作者"/>
                <TableColumn fx:id="createTimeColumn" prefWidth="150.0" text="发布时间"/>
                <TableColumn fx:id="likeCountColumn" prefWidth="80.0" text="点赞数"/>
                <TableColumn fx:id="commentCountColumn" prefWidth="80.0" text="评论数"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Button fx:id="prevButton" mnemonicParsing="false" text="上一页"/>
                <Label fx:id="pageInfoLabel" text=""/>
                <Button fx:id="nextButton" mnemonicParsing="false" text="下一页"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>