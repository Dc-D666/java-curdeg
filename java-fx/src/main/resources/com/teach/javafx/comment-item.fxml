<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.teach.javafx.controller.CommentItemController" spacing="8.0" styleClass="comment-card" stylesheets="@css/bbs-comments.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
   </padding>
   <children>
      <HBox fx:id="authorBox" spacing="8.0" alignment="CENTER_LEFT">
         <children>
            <ImageView fx:id="avatarImageView" fitHeight="24.0" fitWidth="24.0" preserveRatio="true" />
            <Label fx:id="authorLabel" styleClass="comment-author" text="作者" />
            <Button fx:id="followButton" mnemonicParsing="false" styleClass="mini-button" text="关注" />
         </children>
      </HBox>
      <Label fx:id="contentLabel" wrapText="true" styleClass="comment-content" text="评论内容" />
      <FlowPane fx:id="commentImagesVBox" hgap="8.0" vgap="8.0" />
      <VBox fx:id="commentAttachmentsVBox" spacing="6.0" />
      <HBox fx:id="bottomBox" spacing="10.0" alignment="CENTER_LEFT" styleClass="comment-actions">
         <children>
            <Label fx:id="timeLabel" styleClass="comment-time" text="时间" />
            <Button fx:id="likeButton" mnemonicParsing="false" styleClass="text-button" text="点赞" />
            <Button fx:id="replyButton" mnemonicParsing="false" styleClass="text-button" text="回复" />
            <Button fx:id="reportButton" mnemonicParsing="false" styleClass="text-button" text="举报" />
         </children>
      </HBox>
      <VBox fx:id="replyVBox" spacing="5.0" />
   </children>
</VBox>
