<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.teach.javafx.controller.CommentItemController" spacing="5.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <HBox fx:id="authorBox" spacing="5.0" alignment="CENTER_LEFT">
         <children>
            <ImageView fx:id="avatarImageView" fitHeight="24.0" fitWidth="24.0" preserveRatio="true" />
            <Label fx:id="authorLabel" style="-fx-font-weight: bold;" text="作者" />
            <Button fx:id="followButton" mnemonicParsing="false" style="-fx-font-size: 11px;" text="关注" />
         </children>
      </HBox>
      <Label fx:id="contentLabel" wrapText="true" text="评论内容" />
      <VBox fx:id="commentImagesVBox" spacing="5.0" />
      <HBox fx:id="bottomBox" spacing="10.0" alignment="CENTER_LEFT">
         <children>
            <Label fx:id="timeLabel" style="-fx-font-size: 11px; -fx-text-fill: gray;" text="时间" />
            <Button fx:id="likeButton" mnemonicParsing="false" style="-fx-font-size: 11px;" text="点赞" />
            <Button fx:id="replyButton" mnemonicParsing="false" style="-fx-font-size: 11px;" text="回复" />
            <Button fx:id="reportButton" mnemonicParsing="false" style="-fx-font-size: 11px;" text="举报" />
         </children>
      </HBox>
      <VBox fx:id="replyVBox" spacing="5.0" />
   </children>
</VBox>
