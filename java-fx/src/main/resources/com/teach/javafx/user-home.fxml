<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="profile-scroll-pane" stylesheets="@css/personal-center.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teach.javafx.controller.UserHomeController">
    <content>
        <VBox spacing="18.0" styleClass="profile-page">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <children>
                <VBox spacing="14.0" styleClass="profile-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Button fx:id="backButton" mnemonicParsing="false" styleClass="btn-secondary" text="返回" />
                                <Label styleClass="profile-subtitle" text="/" />
                                <Label fx:id="breadcrumbLabel" styleClass="section-title" text="用户主页" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="18.0">
                            <children>
                                <ImageView fx:id="avatarImageView" fitHeight="86.0" fitWidth="86.0" preserveRatio="true" styleClass="avatar-circle" />

                                <VBox alignment="CENTER_LEFT" spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="nicknameLabel" styleClass="profile-title" />
                                        <Label fx:id="signatureLabel" styleClass="profile-subtitle" wrapText="true" />

                                        <HBox spacing="18.0">
                                            <children>
                                                <VBox alignment="CENTER" spacing="2.0">
                                                    <children>
                                                        <Label fx:id="postCountLabel" styleClass="stats-value" />
                                                        <Label styleClass="stats-label" text="帖子" />
                                                    </children>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="2.0">
                                                    <children>
                                                        <Label fx:id="followerCountLabel" styleClass="stats-value" />
                                                        <Label styleClass="stats-label" text="粉丝" />
                                                    </children>
                                                </VBox>
                                                <VBox alignment="CENTER" spacing="2.0">
                                                    <children>
                                                        <Label fx:id="followingCountLabel" styleClass="stats-value" />
                                                        <Label styleClass="stats-label" text="关注" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="actionButtonsVBox" alignment="CENTER_RIGHT" spacing="8.0">
                                    <children>
                                        <Button fx:id="followButton" mnemonicParsing="false" prefWidth="100.0" styleClass="btn-edit" text="关注" />
                                        <Button fx:id="messageButton" mnemonicParsing="false" prefWidth="100.0" styleClass="btn-save" text="私信" />
                                        <Button fx:id="reportButton" mnemonicParsing="false" prefWidth="100.0" styleClass="btn-secondary" text="举报" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="profile-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label styleClass="section-title" text="TA 的帖子" />
                                <ProgressIndicator fx:id="refreshProgressIndicator" prefHeight="24.0" prefWidth="24.0" visible="false" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="refreshButton" mnemonicParsing="false" styleClass="btn-secondary" text="刷新" />
                            </children>
                        </HBox>

                        <Separator />

                        <VBox fx:id="postListVBox" spacing="10.0">
                            <padding>
                                <Insets bottom="6.0" left="2.0" right="2.0" top="2.0" />
                            </padding>
                        </VBox>

                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="prevPageButton" mnemonicParsing="false" styleClass="btn-secondary" text="上一页" />
                                <Label fx:id="pageInfoLabel" styleClass="profile-subtitle" text="第 1 页 / 共 1 页" />
                                <Button fx:id="nextPageButton" mnemonicParsing="false" styleClass="btn-secondary" text="下一页" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
