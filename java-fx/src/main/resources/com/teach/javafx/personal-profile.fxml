<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="com.teach.javafx.controller.PersonalProfileController" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <children>
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="个人资料"/>
        <VBox spacing="15.0" alignment="CENTER">
            <children>
                <ImageView fx:id="avatarImageView" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" style="-fx-border-radius: 60; -fx-background-radius: 60;"/>
            </children>
        </VBox>
        <GridPane hgap="10.0" vgap="10.0">
            <children>
                <Label text="学号:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="studentIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="昵称:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="nicknameTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="个性签名:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextArea fx:id="signatureTextArea" prefWidth="300.0" prefHeight="80.0" editable="false" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="头像URL:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="avatarUrlTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                
                <Label text="姓名:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="personNameTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <ComboBox fx:id="namePrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                
                <Label text="学院:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextField fx:id="personDeptTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <ComboBox fx:id="deptPrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                
                <Label text="性别:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <ComboBox fx:id="personGenderComboBox" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                <ComboBox fx:id="genderPrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="6"/>
                
                <Label text="生日:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                <TextField fx:id="personBirthdayTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                <ComboBox fx:id="birthdayPrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="7"/>
                
                <Label text="邮箱:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                <TextField fx:id="personEmailTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                <ComboBox fx:id="emailPrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="8"/>
                
                <Label text="电话:" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                <TextField fx:id="personPhoneTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                <ComboBox fx:id="phonePrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="9"/>
                
                <Label text="地址:" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
                <TextField fx:id="personAddressTextField" prefWidth="300.0" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="10"/>
                <ComboBox fx:id="addressPrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="10"/>
                
                <Label text="个人简介:" GridPane.columnIndex="0" GridPane.rowIndex="11"/>
                <TextArea fx:id="personIntroduceTextArea" prefWidth="300.0" prefHeight="80.0" editable="false" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="11"/>
                <ComboBox fx:id="introducePrivacyComboBox" prefWidth="150.0" GridPane.columnIndex="2" GridPane.rowIndex="11"/>
            </children>
        </GridPane>
        <GridPane hgap="20.0" vgap="10.0" style="-fx-background-color: #f5f5f5; -fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <VBox spacing="5.0" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <children>
                        <Label fx:id="postCountLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4a90e2;" text="0"/>
                        <Label text="发帖数"/>
                    </children>
                </VBox>
                <VBox spacing="5.0" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <children>
                        <Label fx:id="followingCountLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4a90e2;" text="0"/>
                        <Label text="关注数"/>
                    </children>
                </VBox>
                <VBox spacing="5.0" alignment="CENTER" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <children>
                        <Label fx:id="followerCountLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4a90e2;" text="0"/>
                        <Label text="粉丝数"/>
                    </children>
                </VBox>
            </children>
        </GridPane>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="editButton" mnemonicParsing="false" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-padding: 8 20;" text="编辑"/>
                <Button fx:id="saveButton" mnemonicParsing="false" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-padding: 8 20;" text="保存" visible="false"/>
                <Button fx:id="cancelButton" mnemonicParsing="false" style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-padding: 8 20;" text="取消" visible="false"/>
            </children>
        </HBox>
    </children>
</VBox>
