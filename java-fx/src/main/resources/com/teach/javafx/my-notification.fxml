<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.MyNotificationController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="我的通知" />
            <Label fx:id="unreadCountLabel" style="-fx-text-fill: red;" text="(0 条未读)" />
            <ComboBox fx:id="typeComboBox" prefWidth="150.0" />
            <Button fx:id="markAllReadButton" mnemonicParsing="false" text="一键全部已读" />
         </children>
      </HBox>
   </top>
   <center>
      <TableView fx:id="notificationTableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="typeColumn" prefWidth="120.0" text="类型" />
          <TableColumn fx:id="titleColumn" prefWidth="200.0" text="标题" />
          <TableColumn fx:id="contentColumn" prefWidth="300.0" text="内容" />
          <TableColumn fx:id="isReadColumn" prefWidth="80.0" text="状态" />
          <TableColumn fx:id="createTimeColumn" prefWidth="150.0" text="时间" />
        </columns>
      </TableView>
   </center>
</BorderPane>
