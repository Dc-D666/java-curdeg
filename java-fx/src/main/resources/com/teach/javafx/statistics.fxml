<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.XYChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.StatisticsController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="数据统计" />
         </children>
      </VBox>
   </top>
   <center>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="每日发帖量">
            <content>
               <LineChart fx:id="dailyPostChart" animated="false">
                  <xAxis>
                     <NumberAxis fx:id="xAxis" label="日期" />
                  </xAxis>
                  <yAxis>
                     <NumberAxis fx:id="yAxis" label="发帖量" />
                  </yAxis>
               </LineChart>
            </content>
          </Tab>
          <Tab text="热门帖子 Top10">
            <content>
               <TableView fx:id="hotPostTableView" prefHeight="200.0" prefWidth="200.0">
                 <columns>
                   <TableColumn fx:id="hotPostTitleColumn" prefWidth="300.0" text="标题" />
                   <TableColumn fx:id="hotPostAuthorColumn" prefWidth="100.0" text="作者" />
                   <TableColumn fx:id="hotPostLikeCountColumn" prefWidth="80.0" text="点赞数" />
                   <TableColumn fx:id="hotPostCommentCountColumn" prefWidth="80.0" text="评论数" />
                 </columns>
               </TableView>
            </content>
          </Tab>
          <Tab text="活跃用户 Top10">
            <content>
               <TableView fx:id="activeUserTableView" prefHeight="200.0" prefWidth="200.0">
                 <columns>
                   <TableColumn fx:id="activeUserNicknameColumn" prefWidth="150.0" text="昵称" />
                   <TableColumn fx:id="activeUserStudentIdColumn" prefWidth="120.0" text="学号" />
                   <TableColumn fx:id="activeUserPostCountColumn" prefWidth="80.0" text="发帖数" />
                   <TableColumn fx:id="activeUserCommentCountColumn" prefWidth="80.0" text="评论数" />
                 </columns>
               </TableView>
            </content>
          </Tab>
        </tabs>
      </TabPane>
   </center>
</BorderPane>
