<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:controller="com.teach.javafx.controller.PostListController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label text="板块：" />
            <ComboBox fx:id="boardComboBox" prefWidth="150.0" />
            <TextField fx:id="keywordTextField" prefWidth="600.0" promptText="搜索帖子标题或内容...或在此粘贴分享链接" HBox.hgrow="ALWAYS" />
            <Button fx:id="searchButton" mnemonicParsing="false" style="-fx-background-color: #1890ff; -fx-text-fill: white;" text="搜索" />
            <Button fx:id="publishButton" mnemonicParsing="false" text="发布帖子" />
            <Button fx:id="refreshButton" mnemonicParsing="false" text="刷新" />
         </children>
      </HBox>
   </top>
   <center>
      <TableView fx:id="postTableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="titleColumn" prefWidth="300.0" text="标题" />
          <TableColumn fx:id="authorColumn" prefWidth="100.0" text="作者" />
          <TableColumn fx:id="createTimeColumn" prefWidth="150.0" text="发布时间" />
          <TableColumn fx:id="likeCountColumn" prefWidth="80.0" text="点赞数" />
          <TableColumn fx:id="commentCountColumn" prefWidth="80.0" text="评论数" />
          <TableColumn fx:id="statusColumn" prefWidth="100.0" text="状态" />
          <TableColumn fx:id="moderationStatusColumn" prefWidth="100.0" text="审核状态" />
        </columns>
      </TableView>
   </center>
   <bottom>
      <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label fx:id="pageInfoLabel" text="共 0 条，第 1 页" />
            <Label text="每页显示：" />
            <ComboBox fx:id="pageSizeComboBox" prefWidth="80.0" />
            <Button fx:id="prevButton" mnemonicParsing="false" text="上一页" />
            <Button fx:id="nextButton" mnemonicParsing="false" text="下一页" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
