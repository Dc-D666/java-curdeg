<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>

<BorderPane minHeight="0.0" minWidth="0.0" fx:controller="com.teach.javafx.controller.PostSearchController"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <fx:define>
        <ToggleGroup fx:id="searchModeGroup"/>
    </fx:define>
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <ToggleButton fx:id="titleSearchBtn" selected="true" text="标题检索" toggleGroup="$searchModeGroup"/>
                        <ToggleButton fx:id="fulltextSearchBtn" text="全文检索" toggleGroup="$searchModeGroup"/>
                        <ToggleButton fx:id="aiSearchBtn" text="AI 检索" toggleGroup="$searchModeGroup"/>
                        <Label fx:id="aiSearchLimitLabel" managed="false" visible="false" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #52c41a; -fx-background-color: #f6ffed; -fx-padding: 2 6; -fx-background-radius: 4;"/>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="keywordTextField" prefWidth="600.0" promptText="输入帖子标题关键词..." HBox.hgrow="ALWAYS"/>
                        <Button fx:id="searchButton" mnemonicParsing="false" style="-fx-background-color: #1890ff; -fx-text-fill: white;" text="搜索"/>
                        <Button fx:id="refreshButton" mnemonicParsing="false" text="刷新"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true"
                    vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="searchContentBox" fillWidth="true" spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="0.0"/>
                    </padding>
                    <children>
                        <Label fx:id="progressLabel" managed="false" visible="false" text="正在搜索..."
                               style="-fx-font-size: 13px; -fx-text-fill: #52c41a; -fx-padding: 5;"/>
                        <VBox fx:id="aiAnswerBox" managed="false" visible="false" spacing="10.0"
                              style="-fx-background-color: #f0f7ff; -fx-border-color: #1890ff; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="AI 智能回答"
                                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1890ff;"/>
                                        <Button fx:id="formatAnswerBtn" mnemonicParsing="false"
                                                style="-fx-background-color: #52c41a; -fx-text-fill: white;" text="格式化显示"/>
                                        <Button fx:id="copyAnswerBtn" mnemonicParsing="false"
                                                style="-fx-background-color: #1890ff; -fx-text-fill: white;" text="复制答案"/>
                                    </children>
                                </HBox>
                                <TextFlow fx:id="aiAnswerTextFlow"/>
                            </children>
                        </VBox>
                        <VBox fx:id="relatedPostsBox" managed="false" visible="false" spacing="5.0">
                            <children>
                                <Label text="相关帖子" style="-fx-font-weight: bold;"/>
                                <TableView fx:id="relatedPostsTable" minHeight="140.0" prefHeight="150.0">
                                    <columns>
                                        <TableColumn fx:id="relatedTitleColumn" prefWidth="300.0" text="标题"/>
                                        <TableColumn fx:id="relatedAuthorColumn" prefWidth="100.0" text="作者"/>
                                        <TableColumn fx:id="relatedCreateTimeColumn" prefWidth="140.0" text="发布时间"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox fx:id="emptyResultBox" managed="false" visible="false" spacing="10.0"
                              style="-fx-background-color: #fff7e6; -fx-border-color: #faad14; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 20; -fx-alignment: center;">
                            <children>
                                <Label fx:id="emptyTitleLabel" text="未找到相关帖子"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d46b08;"/>
                                <Label fx:id="emptyDescLabel" text="可以发布一个问题，让大家来帮你解答。"
                                       style="-fx-font-size: 13px; -fx-text-fill: #595959;"/>
                                <Button fx:id="quickPostBtn" mnemonicParsing="false"
                                        style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-font-weight: bold;" text="快速发帖"/>
                            </children>
                        </VBox>
                        <VBox fx:id="normalSearchBox" minHeight="320.0" spacing="5.0">
                            <children>
                                <TableView fx:id="postTableView" minHeight="260.0" prefHeight="430.0">
                                    <columns>
                                        <TableColumn fx:id="titleColumn" maxWidth="200.0" minWidth="150.0" prefWidth="200.0" text="标题"/>
                                        <TableColumn fx:id="snippetColumn" maxWidth="400.0" minWidth="200.0" prefWidth="300.0" text="帖子内容"/>
                                        <TableColumn fx:id="authorColumn" maxWidth="120.0" minWidth="80.0" prefWidth="100.0" text="作者"/>
                                        <TableColumn fx:id="createTimeColumn" maxWidth="160.0" minWidth="120.0" prefWidth="140.0" text="发布时间"/>
                                        <TableColumn fx:id="likeCountColumn" maxWidth="80.0" minWidth="50.0" prefWidth="60.0" text="点赞数"/>
                                        <TableColumn fx:id="commentCountColumn" maxWidth="80.0" minWidth="50.0" prefWidth="60.0" text="评论数"/>
                                        <TableColumn fx:id="statusColumn" maxWidth="90.0" minWidth="60.0" prefWidth="70.0" text="状态"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
