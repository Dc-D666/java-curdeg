<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.PostSearchController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <fx:define>
        <ToggleGroup fx:id="searchModeGroup"/>
    </fx:define>
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
            <ToggleButton fx:id="titleSearchBtn" text="标题检索" selected="true" toggleGroup="$searchModeGroup" />
            <ToggleButton fx:id="fulltextSearchBtn" text="全文检索" toggleGroup="$searchModeGroup" />
            <ToggleButton fx:id="aiSearchBtn" text="AI检索" toggleGroup="$searchModeGroup" />
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="keywordTextField" prefWidth="600.0" promptText="输入帖子标题关键词..." HBox.hgrow="ALWAYS" />
            <Button fx:id="searchButton" mnemonicParsing="false" style="-fx-background-color: #1890ff; -fx-text-fill: white;" text="搜索" />
            <Button fx:id="refreshButton" mnemonicParsing="false" text="刷新" />
         </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TableView fx:id="postTableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="titleColumn" prefWidth="200.0" text="标题" maxWidth="200.0" minWidth="150.0"/>
                <TableColumn fx:id="snippetColumn" prefWidth="300.0" text="帖子内容" maxWidth="400.0" minWidth="200.0"/>
                <TableColumn fx:id="authorColumn" prefWidth="100.0" text="作者" maxWidth="120.0" minWidth="80.0"/>
                <TableColumn fx:id="createTimeColumn" prefWidth="140.0" text="发布时间" maxWidth="160.0" minWidth="120.0"/>
                <TableColumn fx:id="likeCountColumn" prefWidth="60.0" text="点赞数" maxWidth="80.0" minWidth="50.0"/>
                <TableColumn fx:id="commentCountColumn" prefWidth="60.0" text="评论数" maxWidth="80.0" minWidth="50.0"/>
                <TableColumn fx:id="statusColumn" prefWidth="70.0" text="状态" maxWidth="90.0" minWidth="60.0"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Label fx:id="pageInfoLabel" text=""/>
                <Label text="每页显示："/>
                <ComboBox fx:id="pageSizeComboBox" prefWidth="80.0"/>
                <Button fx:id="prevButton" mnemonicParsing="false" text="上一页"/>
                <Button fx:id="nextButton" mnemonicParsing="false" text="下一页"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
