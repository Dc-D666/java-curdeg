<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.teach.javafx.controller.UserStatisticsController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="我的数据统计" />
         </children>
      </VBox>
   </top>
   <center>
      <GridPane alignment="CENTER" hgap="20.0" vgap="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #e3f2fd; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="0" GridPane.rowIndex="0">
               <children>
                  <Label fx:id="postCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1976d2;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="发帖数" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #f3e5f5; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <children>
                  <Label fx:id="commentCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #7b1fa2;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="评论数" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #e8f5e9; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="2" GridPane.rowIndex="0">
               <children>
                  <Label fx:id="likeCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #388e3c;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="获赞总数" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #fff3e0; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <children>
                  <Label fx:id="favoriteCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f57c00;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="被收藏数" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #ffebee; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <Label fx:id="viewCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="总浏览量" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #e0f7fa; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="2" GridPane.rowIndex="1">
               <children>
                  <Label fx:id="followingCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0097a7;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="关注数" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="180.0" spacing="10.0" style="-fx-background-color: #fce4ec; -fx-background-radius: 10; -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <Label fx:id="followerCountLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #c2185b;" text="0" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #424242;" text="粉丝数" />
               </children>
            </VBox>
         </children>
      </GridPane>
   </center>
</BorderPane>
